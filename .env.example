# Copy this file to .env.local (for local dev) and also set each value as
# an Environment Variable in your Vercel project settings (for prod).
#
# NEXT_PUBLIC_* are exposed to the browser bundle. Everything else is
# server-only and must NEVER be prefixed with NEXT_PUBLIC_.

# ─── Supabase ────────────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Project Settings → API → anon / public key (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Project Settings → API → service_role key (NEVER expose; used by the
# Stripe webhook to bypass RLS when writing subscription rows).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ──────────────────────────────────────────────────────────
# Developers → API keys → Secret key. Use sk_test_* for dev, sk_live_* in prod.
STRIPE_SECRET_KEY=sk_test_...

# Developers → Webhooks → your endpoint → Signing secret.
# For local dev, use `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# and copy the `whsec_...` it prints.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Site ────────────────────────────────────────────────────────────
# Public origin of your site. Used in auth email redirects and Stripe
# checkout success/cancel URLs. Do NOT include a trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin/application notifications. Coach applications are sent here.
APPLICATIONS_EMAIL=christopher.perry@theshapecommunity.com

# Comma-separated website admin emails allowed to review applications.
ADMIN_EMAILS=christopher.perry@theshapecommunity.com,cperry8800@gmail.com

# ─── hCaptcha (optional) ─────────────────────────────────────────────
# Uncomment and fill if you enable CAPTCHA protection in Supabase Auth
# settings. Without this var the phone login page skips the widget.
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001

# â”€â”€â”€ Third-party integrations â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Spotify Developer Dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Strava API Settings
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# WHOOP Developer Dashboard. Uses OAuth scopes configured in
# src/lib/integrations/providers.ts.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Garmin Health API credentials. Garmin access requires approval through
# the Garmin Connect Developer Program before production data will sync.
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Apple Music / MusicKit. Generate a MusicKit private key in Apple Developer.
# Store the .p8 with escaped newlines in Vercel, e.g. -----BEGIN PRIVATE KEY-----\n...
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=
