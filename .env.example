# Copy this file to .env.local (for local dev) and also set each value as
# an Environment Variable in your Vercel project settings (for prod).
#
# NEXT_PUBLIC_* are exposed to the browser bundle. Everything else is
# server-only and must NEVER be prefixed with NEXT_PUBLIC_.

# ─── Supabase ────────────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Project Settings → API → anon / public key (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Project Settings → API → service_role key (NEVER expose; used by the
# Stripe webhook to bypass RLS when writing subscription rows).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ──────────────────────────────────────────────────────────
# Developers → API keys → Secret key. Use sk_test_* for dev, sk_live_* in prod.
STRIPE_SECRET_KEY=sk_test_...

# Developers → Webhooks → your endpoint → Signing secret.
# For local dev, use `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# and copy the `whsec_...` it prints.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Site ────────────────────────────────────────────────────────────
# Public origin of your site. Used in auth email redirects and Stripe
# checkout success/cancel URLs. Do NOT include a trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── hCaptcha (optional) ─────────────────────────────────────────────
# Uncomment and fill if you enable CAPTCHA protection in Supabase Auth
# settings. Without this var the phone login page skips the widget.
# NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
